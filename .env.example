# ============================================================================
# Relevé Connect — Environment Variables TEMPLATE
# ----------------------------------------------------------------------------
# HOW TO USE THIS FILE:
#   1. Make a COPY of this file in the same folder and name the copy ".env.local"
#   2. Fill in the blank values on the right of each "=" sign
#   3. Never share .env.local or commit it to git (it holds your secrets).
#      This template (.env.example) is safe to commit because it has no secrets.
#
# You do NOT need all of these at once. Each section says when it's needed.
# ============================================================================

# --- Supabase (the database + login + file storage) -------------------------
# Needed once we connect the app to a real database (Step 3).
# Get these from your Supabase project: Settings → API keys.
NEXT_PUBLIC_SUPABASE_URL=
# "Publishable key" (newer name) — safe for the browser. Older projects show this
# as the "anon" key; either works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# "Secret key" (newer name; older projects call it "service_role"). Full admin,
# server-side only. Keep it secret. Needed later for webhooks/admin, not to start.
SUPABASE_SECRET_KEY=

# --- Email (Resend or Postmark) ---------------------------------------------
# Needed once we send onboarding emails. Vendor still to be confirmed.
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# --- Stripe (membership payment + the $499 Signature Experience) ------------
# Start in TEST mode. Get keys from the Stripe dashboard.
# STRIPE_SECRET_KEY is the secret key (sk_test_… in test mode).
STRIPE_SECRET_KEY=
# The webhook signing secret is a DIFFERENT value (whsec_…). You get it when you
# create the webhook endpoint (or from `stripe listen`). Needed by Flow C.
STRIPE_WEBHOOK_SIGNING_SECRET=

# --- Stripe Connect: the $499 Signature Experience (docs/STRIPE-CONNECT-499-LICENSING.md) ---
# Comma-separated talent_profile ids that sell WITHOUT a Connect split — the
# founder is artist AND platform, so she keeps 100% (used for the first proof).
# Every other artist must finish Express onboarding (payouts_enabled) and gets 80/20.
FOUNDER_PROFILE_ID=
# Booking links surfaced to the buyer after purchase.
FOUNDER_WELCOME_BOOKING_URL=
DEFAULT_CHECKIN_BOOKING_URL=
# MailerLite ("The Climb") — optional add-on step in the purchase webhook.
MAILERLITE_API_KEY=
MAILERLITE_CLIMB_GROUP_ID=

# --- App ---------------------------------------------------------------------
# The address the site runs at. Local default shown; change for production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
